  "stop_ship_conditions": [
    "privacy_disclosure_runtime_mismatch",
    "required_store_forms_incomplete",
    "sensitive_permission_without_justification",
    "secrets_in_mobile_bundle_or_logs"
  ],
  "disclosure_policy": {
    "privacy_doc": "docs/mobile-privacy-and-disclosures.md",
    "store_disclosure_config": "backend/config/mobile-store-disclosures.json",
    "website_source_alignment": [
      "mjsds-website/docs/visibility-policy.md",
      "mjsds-website/docs/content-playbook.md",
      "mjsds-website/docs/workspace-model.md"
