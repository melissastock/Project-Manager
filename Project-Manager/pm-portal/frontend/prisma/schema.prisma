generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Mirrors `public.recommendation_decisions` (see `../backend/schema/recommendation_decisions.sql`).
model RecommendationDecision {
  recommendation_id String   @id
  state               String   @default("pending")
  rationale           String   @default("")
  owner               String   @default("")
  due_date            String   @default("")
  updated_at          DateTime @default(now()) @db.Timestamptz(6)

  @@map("recommendation_decisions")
}

enum IntegrationProvider {
  GOOGLE
}

enum IntegrationStatus {
  ACTIVE
  REAUTH_REQUIRED
  REVOKED
  DISABLED
}

enum DataClass {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  REGULATED
}

enum AuditAction {
  CONNECT_INITIATED
  CONNECT_COMPLETED
  SCOPES_UPDATED
  TOKEN_REFRESHED
  TOKEN_REFRESH_FAILED
  SYNC_STARTED
  SYNC_COMPLETED
  SYNC_FAILED
  RECORD_ACCESSED
  REVOKED
  PURGED
}

/// Connection metadata per workspace/user/provider account.
model IntegrationConnection {
  id                  String              @id @default(cuid())
  workspaceId         String              @map("workspace_id")
  ownerUserId         String              @map("owner_user_id")
  provider            IntegrationProvider
  providerAccountId   String              @map("provider_account_id")
  email               String?
  status              IntegrationStatus   @default(ACTIVE)
  scopes              String[]
  needsManualOverride Boolean             @default(false) @map("needs_manual_override")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastSyncedAt        DateTime?           @map("last_synced_at") @db.Timestamptz(6)
  oauthCredential     OAuthCredential?
  syncCursors         SyncCursor[]
  auditEvents         IntegrationAuditEvent[]

  @@unique([workspaceId, provider, providerAccountId])
  @@index([workspaceId, provider, status])
  @@map("integration_connections")
}

/// Keep refresh tokens encrypted at rest; never expose this model to the client.
model OAuthCredential {
  id                      String               @id @default(cuid())
  integrationConnectionId String               @unique @map("integration_connection_id")
  encryptedRefreshToken   String               @map("encrypted_refresh_token")
  tokenVersion            Int                  @default(1) @map("token_version")
  accessTokenExpiresAt    DateTime?            @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenIssuedAt    DateTime?            @map("refresh_token_issued_at") @db.Timestamptz(6)
  lastRefreshAt           DateTime?            @map("last_refresh_at") @db.Timestamptz(6)
  refreshFailureCount     Int                  @default(0) @map("refresh_failure_count")
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)

  @@map("oauth_credentials")
}

/// Incremental sync checkpoint per resource type.
model SyncCursor {
  id                      String               @id @default(cuid())
  integrationConnectionId String               @map("integration_connection_id")
  resourceType            String               @map("resource_type")
  cursor                  String?
  lastSuccessfulSyncAt    DateTime?            @map("last_successful_sync_at") @db.Timestamptz(6)
  lastAttemptedSyncAt     DateTime?            @map("last_attempted_sync_at") @db.Timestamptz(6)
  lastError               String?              @map("last_error")
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)

  @@unique([integrationConnectionId, resourceType])
  @@map("sync_cursors")
}

model IntegrationAuditEvent {
  id                      String               @id @default(cuid())
  integrationConnectionId String               @map("integration_connection_id")
  actorUserId             String?              @map("actor_user_id")
  action                  AuditAction
  scopeDelta              Json?                @map("scope_delta")
  resourceType            String?              @map("resource_type")
  resourceId              String?              @map("resource_id")
  metadata                Json?
  dataClass               DataClass            @default(INTERNAL) @map("data_class")
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)

  @@index([integrationConnectionId, createdAt])
  @@index([action, createdAt])
  @@map("integration_audit_events")
}

model DataClassificationPolicy {
  id                        String    @id @default(cuid())
  workspaceId               String    @unique @map("workspace_id")
  gmailDefaultClass         DataClass @default(CONFIDENTIAL) @map("gmail_default_class")
  calendarDefaultClass      DataClass @default(INTERNAL) @map("calendar_default_class")
  storeMessageBodyByDefault Boolean   @default(false) @map("store_message_body_by_default")
  storeAttachmentsByDefault Boolean   @default(false) @map("store_attachments_by_default")
  retentionDaysInternal     Int       @default(365) @map("retention_days_internal")
  retentionDaysConfidential Int       @default(180) @map("retention_days_confidential")
  retentionDaysRegulated    Int       @default(90) @map("retention_days_regulated")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("data_classification_policies")
}

enum AgreementStatus {
  draft
  under_review
  ready_for_signature
  active
  locked
  amended
}

enum PricingModel {
  fixed
  package
  retainer
  mixed
}

enum ChangeOrderStatus {
  requested
  approved
  rejected
  implemented
}

model ClientAgreement {
  id               String                @id
  project          String
  client_name      String
  package_name     String                @default("")
  product_brief    String                @default("")
  scope_definition String                @default("")
  deliverables_summary String            @default("")
  pricing_model    PricingModel          @default(fixed)
  price_terms_json Json
  agreement_status AgreementStatus       @default(draft)
  is_locked        Boolean               @default(false)
  locked_at        DateTime?             @db.Timestamptz(6)
  locked_by        String                @default("")
  lock_reason      String                @default("")
  owner_role       String                @default("business_owner")
  neuro_worker_type String               @default("unspecified")
  intake           Json
  deliverables     Json
  source           String                @default("pm-portal")
  created_at       DateTime              @default(now()) @db.Timestamptz(6)
  updated_at       DateTime              @updatedAt @db.Timestamptz(6)
  messages         AgreementMessage[]
  change_orders    AgreementChangeOrder[]
  audit_events     AgreementAuditEvent[]

  @@index([project])
  @@map("client_agreements")
}

model AgreementMessage {
  id          String          @id
  agreement_id String
  project     String
  author_name String
  author_role String          @default("client")
  message     String
  visibility  String          @default("client_and_team")
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  agreement   ClientAgreement @relation(fields: [agreement_id], references: [id], onDelete: Cascade)

  @@index([agreement_id, created_at])
  @@map("agreement_messages")
}

model AgreementChangeOrder {
  id                      String            @id
  agreement_id            String
  project                 String
  requested_by            String
  requested_scope_delta   String
  requested_price_delta   String            @default("")
  requested_timeline_delta String           @default("")
  status                  ChangeOrderStatus @default(requested)
  approver                String            @default("")
  decision_note           String            @default("")
  created_at              DateTime          @default(now()) @db.Timestamptz(6)
  updated_at              DateTime          @updatedAt @db.Timestamptz(6)
  agreement               ClientAgreement   @relation(fields: [agreement_id], references: [id], onDelete: Cascade)

  @@index([agreement_id, created_at])
  @@map("agreement_change_orders")
}

model AgreementAuditEvent {
  id          String          @id
  agreement_id String
  project     String
  event_type  String
  actor       String          @default("")
  actor_role  String          @default("")
  details     Json
  data_class  String          @default("CONFIDENTIAL")
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  agreement   ClientAgreement @relation(fields: [agreement_id], references: [id], onDelete: Cascade)

  @@index([agreement_id, created_at])
  @@map("agreement_audit_events")
}
